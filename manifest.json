{
  "manifest_version": 3,
  "name": "CSS Weaver",
  "version": "1.0.0",
  "description": "Visualize CSS animations from any website as a timeline (like After Effects)",
  "icons": {
    "16": "public/icons/icon-16.svg",
    "48": "public/icons/icon-48.svg",
    "128": "public/icons/icon-128.svg"
  },
  "action": {
    "default_icon": {
      "16": "public/icons/icon-16.svg",
      "48": "public/icons/icon-48.svg"
    },
    "default_title": "Open CSS Weaver"
  },
  "background": {
    "service_worker": "src/background/service-worker.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/index.ts"],
      "run_at": "document_idle"
    }
  ],
  "permissions": [
    "activeTab",
    "tabs",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "web_accessible_resources": [
    {
      "resources": ["public/pageScript.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
